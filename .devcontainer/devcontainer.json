{
    "name": "NVIDIA PyTorch Geometric Dev Container",
    "image": "nvcr.io/nvidia/pytorch:26.03-py3",
    "runArgs": [
        "--gpus=all",
        "--ipc=host",
        "--add-host=host.docker.internal:host-gateway"
    ],
    "mounts": [
        "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached"
    ],
    "workspaceFolder": "/workspace",
    "postCreateCommand": "apt-get update && apt-get install -y python3-tk curl && curl -sSL https://install.python-poetry.org | python3 - && /root/.local/bin/poetry config virtualenvs.create false && /root/.local/bin/poetry install --without torch",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-toolsai.jupyter",
                "GitHub.copilot"
            ]
        }
    },
    "containerEnv": {
        "NO_PROXY": "localhost,127.0.0.1,tail242f84.ts.net",
        "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True"
    }
}