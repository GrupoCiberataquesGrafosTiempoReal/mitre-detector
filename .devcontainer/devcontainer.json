{
    "name": "NVIDIA PyTorch Geometric Dev Container",
    "image": "nvcr.io/nvidia/pytorch:26.03-py3",
    "runArgs": [
        "--gpus=all",
        "--ipc=host"
    ],
    "mounts": [
        "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached"
    ],
    "workspaceFolder": "/workspace",
    "postCreateCommand": "apt-get update && apt-get install -y python3-tk && pip install matplotlib seaborn pandas numpy tabulate fastparquet pyarrow scikit-learn torch_geometric neo4j dotenv",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-toolsai.jupyter",
                "GitHub.copilot"
            ]
        }
    },
    "containerEnv": {
        "NO_PROXY": "localhost,127.0.0.1,tail242f84.ts.net",
        "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True"
    }
}